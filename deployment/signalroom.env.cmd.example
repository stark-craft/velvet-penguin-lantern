@echo off
rem Copy this file to signalroom.env.cmd and edit it for the server laptop.
rem Do not commit the copied file because it contains the deployment secret.

set "SIGNALROOM_ENV=production"
set "SIGNALROOM_HOST=0.0.0.0"
set "SIGNALROOM_PORT=8000"
set "SIGNALROOM_FRONTEND_PORT=3000"
set "SIGNALROOM_CORS_ORIGINS=http://192.0.2.10:3000"
set "SIGNALROOM_TIMEZONE=Asia/Kolkata"

set "SIGNALROOM_SCHEDULER_ENABLED=true"
set "SIGNALROOM_SCHEDULE_INTERVAL_HOURS=4"
set "SIGNALROOM_SCHEDULER_RUN_ON_START=true"
set "SIGNALROOM_SCHEDULER_STARTUP_DELAY_SECONDS=10"
set "SIGNALROOM_SCHEDULER_MISFIRE_GRACE_SECONDS=3600"
set "SIGNALROOM_SCHEDULER_STALE_JOB_HOURS=8"
set "SIGNALROOM_MAX_REQUEST_BYTES=1048576"
set "SIGNALROOM_MUTATION_RATE_LIMIT_PER_MINUTE=120"
set "SIGNALROOM_STREAM_CRAWLER_LOGS=true"

set "SIGNALROOM_HF_LOCAL_ONLY=true"
set "SIGNALROOM_EMBEDDING_MODEL_PATH=%~dp0backend\model_weights\all-MiniLM-L6-v2"
set "SIGNALROOM_SUMMARIZATION_MODEL_PATH=%~dp0backend\model_weights\distilbart-cnn-12-6"
set "SIGNALROOM_IP_HASH_SECRET=replace-with-at-least-32-random-secret-bytes"
set "SIGNALROOM_APPROVAL_KEY=2741"
set "SIGNALROOM_GATEKEEPER_KEY=6384"
set "SIGNALROOM_BROADCAST_IPS="
set "SIGNALROOM_DEVELOPER_IPS=127.0.0.1,::1"
set "SIGNALROOM_ADMIN_IPS="
set "SIGNALROOM_TRUST_PROXY_HEADERS=false"
set "SIGNALROOM_TRUST_IDENTITY_HEADERS=false"
rem Required (32+ random characters) only when a company proxy/BFF is trusted.
set "SIGNALROOM_PROXY_SHARED_SECRET="
