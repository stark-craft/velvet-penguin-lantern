# New pipeline idea only. This file contains placeholders, never credentials.
# The active main.py scheduler does not read or activate this pipeline.

# Samsung Web Search: discovery links -> authoritative article extraction
SAMSUNG_WEB_SEARCH_URL=https://genai-openapi.sec.samsung.net/swahq/trial/api-web-search/openapi/web-search/v1/search
SAMSUNG_WEB_SEARCH_CLIENT=replace-with-company-client
SAMSUNG_WEB_SEARCH_TOKEN=replace-with-company-token
SAMSUNG_WEB_SEARCH_TIMEOUT=90

# Samsung Chat: clustered events -> executive feed summaries
SAMSUNG_CHAT_URL=https://genai-openapi.sec.samsung.net/swahq/trial/api-chat/openapi/chat/v1/messages
SAMSUNG_CHAT_CLIENT=replace-with-company-client
SAMSUNG_CHAT_TOKEN=replace-with-company-token
SAMSUNG_CHAT_MODEL_ID=replace-with-approved-model-id
SAMSUNG_CHAT_TIMEOUT=180

# Secure certificate verification remains enabled.
NEWSSCRAPPER_USE_SYSTEM_CA=true
# REQUESTS_CA_BUNDLE=C:\path\to\company-ca-bundle.pem
# SSL_CERT_FILE=C:\path\to\company-ca-bundle.pem

# Both values are hard-capped at three by main_new_pipeline_idea.py.
NEW_PIPELINE_IDEA_WEB_SEARCH_RPM=3
NEW_PIPELINE_IDEA_CHAT_RPM=3
NEW_PIPELINE_IDEA_MAX_ATTEMPTS=3
NEW_PIPELINE_IDEA_RETRY_BACKOFF_SECONDS=5

# Existing profile bouncer and local MiniLM clustering.
NEW_PIPELINE_IDEA_BOUNCER_LOW_THRESHOLD=0.45
NEW_PIPELINE_IDEA_BOUNCER_DROP_THRESHOLD=0.60
NEW_PIPELINE_IDEA_CLUSTER_DISTANCE=0.32
NEW_PIPELINE_IDEA_KEEP_DEBUG_FIELDS=false

# The image adapter only fills a missing top_image.
ARTICLE_IMAGE_METADATA_ENABLED=true
ARTICLE_IMAGE_METADATA_TIMEOUT=12
