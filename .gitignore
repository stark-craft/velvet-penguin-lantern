# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
*.egg-info/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Local OpenAI Sites binding. The internal-laptop build does not require it,
# and a deployment-specific project identifier must not be published.
/.openai/hosting.json

# typescript
next-env.d.ts
*.tsbuildinfo
/dist/
/.wrangler/
/outputs/
/work/

# Signalroom local state, crawl output, scheduler locks, and trained gatekeeper
# artifacts are generated per deployment. Preserve them during upgrades, but do
# not publish them as source.
/backend/runtime/*
!/backend/runtime/.gitkeep
/backend/models/*
!/backend/models/.gitkeep

# Local portable-release material and secrets.
/signalroom.env.cmd
/deployment/signalroom.env.cmd
/python_embed/
/node_embed/
/logs/
