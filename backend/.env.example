SIGNALROOM_ENV=development
SIGNALROOM_HOST=127.0.0.1
SIGNALROOM_PORT=8000
SIGNALROOM_CORS_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:5173,http://localhost:3000,http://localhost:5173

# Runtime state is intentionally outside the frontend and source configuration.
SIGNALROOM_STORAGE_PATH=runtime/data
SIGNALROOM_PROFILE_DIR=profiles
SIGNALROOM_SITES_DIR=sites
SIGNALROOM_MODEL_DIR=models
SIGNALROOM_CRAWL_OUTPUT_DIR=runtime/crawls

SIGNALROOM_SCHEDULER_ENABLED=true
SIGNALROOM_SCHEDULE_INTERVAL_HOURS=4
SIGNALROOM_SCHEDULER_RUN_ON_START=true
SIGNALROOM_SCHEDULER_STARTUP_DELAY_SECONDS=10
SIGNALROOM_SCHEDULER_MISFIRE_GRACE_SECONDS=3600
SIGNALROOM_SCHEDULER_STALE_JOB_HOURS=8
SIGNALROOM_SCHEDULER_RELOAD_PROFILES=true
SIGNALROOM_TIMEZONE=Asia/Kolkata
SIGNALROOM_APPROVAL_KEY=2741
SIGNALROOM_GATEKEEPER_KEY=6384
SIGNALROOM_STREAM_CRAWLER_LOGS=true

# Normal inference is local-only. Keep this true; the download script performs
# the one explicit network step and strict warmup verifies the local folders.
SIGNALROOM_HF_LOCAL_ONLY=true
SIGNALROOM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SIGNALROOM_SUMMARIZATION_MODEL=sshleifer/distilbart-cnn-12-6
# Once downloaded, these optional paths take precedence over the Hub IDs above.
SIGNALROOM_EMBEDDING_MODEL_PATH=model_weights/all-MiniLM-L6-v2
SIGNALROOM_SUMMARIZATION_MODEL_PATH=model_weights/distilbart-cnn-12-6

# Never put a production secret into source control.
SIGNALROOM_ADMIN_KEY=
SIGNALROOM_ADMIN_EMAILS=
SIGNALROOM_ANALYTICS_EMAILS=
SIGNALROOM_ADMIN_IPS=
SIGNALROOM_BROADCAST_IPS=
SIGNALROOM_DEVELOPER_IPS=127.0.0.1,::1
SIGNALROOM_TRUSTED_PROXY_IPS=127.0.0.1,::1
SIGNALROOM_TRUST_PROXY_HEADERS=false
SIGNALROOM_TRUST_IDENTITY_HEADERS=false
SIGNALROOM_MAX_REQUEST_BYTES=1048576
SIGNALROOM_MUTATION_RATE_LIMIT_PER_MINUTE=120
SIGNALROOM_IP_HASH_SECRET=replace-with-a-long-random-secret
SIGNALROOM_APPROVAL_KEY=2741
